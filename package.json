{
  "name": "android-string-manager",
  "version": "2.0.0",
  "description": "MCP server for managing Android string resources across multiple locales",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "android-string-manager": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "android",
    "strings",
    "localization",
    "i18n"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
